pipeline {
    agent {
        dockerfile {
            filename 'ci/Dockerfile'
            args '-u 0:0 -v gradle-cache:/root/.gradle -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        GRADLE_USER_HOME = '/root/.gradle'
    }

    options {
        timeout(time: 10, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Build') {
            steps {
                sh 'mkdir -p /root/.gradle/chaekpool-api && ln -sfn /root/.gradle/chaekpool-api .gradle'
                sh './gradlew assemble --no-daemon'
            }
        }

        stage('Test') {
            steps {
                sh './gradlew cleanTest test --no-daemon'
            }
            post {
                always {
                    junit '**/build/test-results/test/*.xml'
                }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([file(credentialsId: 'api-env', variable: 'API_ENV_FILE')]) {
                    sshagent(credentials: ['api-deploy-ssh']) {
                        sh 'chmod +x ci/deploy.sh && ci/deploy.sh'
                    }
                }
            }
        }
    }

    post {
        success { echo 'Pipeline completed successfully' }
        failure { echo 'Pipeline failed' }
    }
}
