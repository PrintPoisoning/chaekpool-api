pipeline {
    agent {
        docker {
            image 'gradle:jdk25-alpine'
            args '-u 0:0 -v gradle-cache:/root/.gradle -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Build') {
            steps {
                sh './gradlew clean build -x test --no-daemon'
            }
        }

        stage('Test') {
            steps {
                sh './gradlew test --no-daemon'
            }
            post {
                always {
                    junit '**/build/test-results/test/*.xml'
                }
            }
        }

        stage('Deploy') {
            steps {
                sh 'apk add --no-cache openssh-client'
                withCredentials([file(credentialsId: "api-env-${params.DEPLOY_ENV}", variable: 'API_ENV_FILE')]) {
                    sshagent(credentials: ['api-deploy-ssh']) {
                        sh 'chmod +x ci/deploy.sh && ci/deploy.sh'
                    }
                }
            }
        }
    }

    post {
        success { echo 'Pipeline completed successfully' }
        failure { echo 'Pipeline failed' }
        cleanup { cleanWs() }
    }
}
